# ─── App ──────────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Database ─────────────────────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=ridesync
DB_PASSWORD=change_this_strong_password
DB_NAME=ridesync_db

# ─── Redis ────────────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=change_this_redis_password

# ─── JWT ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change_this_to_a_long_random_secret_min_32_chars
JWT_EXPIRES_IN=7d

# ─── LinkedIn OAuth ───────────────────────────────────────────────────────────
LINKEDIN_CLIENT_ID=your_linkedin_client_id
LINKEDIN_CLIENT_SECRET=your_linkedin_client_secret
LINKEDIN_CALLBACK_URL=https://api.ridesync.pk/api/v1/auth/linkedin/callback

# ─── Email (Resend) ───────────────────────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxxxxxxxxxx
EMAIL_FROM=noreply@ridesync.pk

# ─── Cloudflare R2 ────────────────────────────────────────────────────────────
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key
R2_SECRET_ACCESS_KEY=your_r2_secret_key
R2_BUCKET_NAME=ridesync-assets
R2_PUBLIC_URL=https://assets.ridesync.pk

# ─── Firebase FCM ─────────────────────────────────────────────────────────────
FIREBASE_PROJECT_ID=ridesync-xxxxx
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@ridesync-xxxxx.iam.gserviceaccount.com

# ─── JazzCash ─────────────────────────────────────────────────────────────────
JAZZCASH_MERCHANT_ID=your_merchant_id
JAZZCASH_PASSWORD=your_jazzcash_password
JAZZCASH_INTEGRITY_SALT=your_integrity_salt
JAZZCASH_SANDBOX=false

# ─── EasyPaisa ────────────────────────────────────────────────────────────────
EASYPAISA_STORE_ID=your_store_id
EASYPAISA_HASH_KEY=your_hash_key
EASYPAISA_SANDBOX=false

# ─── Sentry ───────────────────────────────────────────────────────────────────
SENTRY_DSN=https://xxxx@xxxx.ingest.sentry.io/xxxx

# ─── Google Maps ──────────────────────────────────────────────────────────────
GOOGLE_MAPS_API_KEY=your_google_maps_api_key
